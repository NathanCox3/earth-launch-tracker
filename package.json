{
  "name": "earth-launch-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Track upcoming and past rocket launches from Earth with live countdowns, filters, and livestream links.",
  "homepage": "https://nathancox3.github.io/earth-launch-tracker/",
  "scripts": {
    "start": "node --env-file-if-exists=.env ./src/server.mjs",
    "migrate": "node --env-file-if-exists=.env ./src/migrate.mjs",
    "sync:upcoming": "node --env-file-if-exists=.env ./src/sync-cli.mjs upcoming",
    "sync:backfill": "node --env-file-if-exists=.env ./src/sync-cli.mjs backfill",
    "export:static": "node --env-file-if-exists=.env ./scripts/export-launch-tracker-static.mjs",
    "test": "node --test ./src/*.test.mjs"
  },
  "dependencies": {
    "postgres": "^3.4.8"
  },
  "engines": {
    "node": ">=22"
  }
}
